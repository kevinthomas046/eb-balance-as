{
  "name": "attendance",
  "version": "0.0.0",
  "description": "",
  "main": "dist/index.mjs",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [],
  "scripts": {
    "clean": "rimraf build dist",
    "lint": "npm run license && eslint --fix --no-error-on-unmatched-pattern src/ test/",
    "bundle": "rollup --no-treeshake -c rollup.config.mjs",
    "build": "npm run clean && npm run bundle && ncp appsscript.json dist/appsscript.json",
    "license": "license-check-and-add add -f license-config.json",
    "login": "clasp login",
    "clone-pull": "clasp clone && clasp pull --rootDir ./src",
    "deploy": "npm run lint && npm run build && ncp .clasp-dev.json .clasp.json && clasp push -f",
    "deploy:prod": "npm run lint && npm run build && ncp .clasp-prod.json .clasp.json && clasp push"
  },
  "engines": {
    "node": ">=12"
  },
  "dependencies": {
    "@google/clasp": "^2.5.0",
    "@types/google-apps-script": "^1.0.100",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "gts": "^5.3.1",
    "jest": "^29.7.0",
    "license-check-and-add": "^4.0.5",
    "ncp": "^2.0.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-license": "^3.7.1",
    "rollup-plugin-prettier": "^4.1.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.4.11"
  },
  "devDependencies": {
    "@web/rollup-plugin-copy": "^0.5.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
